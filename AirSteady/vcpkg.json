{
  "name": "airsteady-ui",
  "version-string": "0.1.0",
  "description": "AirSteady desktop UI (Qt6 + OpenCV) for video stabilization preview.",
  "dependencies": [
    {
      "name": "qtbase"
    },
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "avfilter",
        "swscale",
        "swresample",
        "gpl",
        "x264",
        "nvcodec",
        "qsv",
        "amf"
      ]
    },
    "opencv4",
    "cxxopts",
    "fmt",
    "glog",
    "eigen3",
    "cereal"
  ],
  "builtin-baseline": "a34c873a9717a888f58dc05268dea15592c2f0ff"
}
